# Public browser URL for the backend REST API.
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080/api

# Public browser URL for the LiveKit websocket endpoint.
NEXT_PUBLIC_WEBSOCKET_URL=ws://localhost:7880

# Public browser URL for the meeting SockJS/STOMP endpoint.
NEXT_PUBLIC_MEETING_SOCKET_URL=http://localhost:8080/server

# Server-side URL used by Next.js route handlers inside Docker.
BACKEND_INTERNAL_URL=http://backend:8080/api

# Optional comma-separated dev origins for Next.js.
NEXT_ALLOWED_DEV_ORIGINS=local-origin.dev,*.local-origin.dev
